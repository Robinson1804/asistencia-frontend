
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity, same as Firebase Auth UID."
        },
        "email": {
          "type": "string",
          "description": "Email address of the user.",
          "format": "email"
        },
        "role": {
          "type": "string",
          "description": "Role of the user in the system.",
          "enum": ["admin", "registrador"]
        }
      },
      "required": ["id", "email", "role"]
    },
    "Employee": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Employee",
      "type": "object",
      "description": "Represents an employee in the system.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Employee entity."
        },
        "firstName": {
          "type": "string",
          "description": "First name of the employee."
        },
        "lastName": {
          "type": "string",
          "description": "Last name of the employee."
        },
        "email": {
          "type": "string",
          "description": "Email address of the employee.",
          "format": "email"
        },
        "phoneNumber": {
          "type": "string",
          "description": "Phone number of the employee."
        },
        "edad": {
            "type": "number",
            "description": "Age of the employee."
        },
        "correoPersonal": {
            "type": "string",
            "description": "Personal email address of the employee.",
            "format": "email"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName",
        "email"
      ]
    },
    "ConocimientoEmpleado": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "title": "ConocimientoEmpleado",
        "type": "object",
        "description": "Represents the skills and knowledge of an employee.",
        "properties": {
            "employeeId": {
                "type": "string",
                "description": "The DNI of the employee this knowledge record belongs to."
            },
            "gradoInstruccion": {
                "type": "string"
            },
            "cargo": {
                "type": "string"
            },
            "añosExperiencia": {
                "type": "string"
            },
            "frontend": {
                "type": "object"
            },
            "backend": {
                "type": "object"
            },
            "databases": {
                "type": "object"
            },
            "devops": {
                "type": "object"
            },
            "proyectosOtin": {
                "type": "string"
            },
            "tecnologiasAprender": {
                "type": "string"
            },
            "otrasTecnologias": {
                "type": "string"
            },
             "updatedAt": {
                "type": "string",
                "format": "date-time"
             }
        },
        "required": ["employeeId"]
    },
    "AttendanceRecord": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AttendanceRecord",
      "type": "object",
      "description": "Represents an attendance record for an employee on a specific date.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the AttendanceRecord entity."
        },
        "employeeId": {
          "type": "string",
          "description": "Reference to Employee. (Relationship: Employee 1:N AttendanceRecord)"
        },
        "date": {
          "type": "string",
          "description": "Date of the attendance record.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Attendance status for the employee on the given date (e.g., Presente, Tardanza, Falta)."
        },
        "notes": {
          "type": "string",
          "description": "Additional notes regarding attendance (e.g., reason for tardiness)."
        }
      },
      "required": [
        "id",
        "employeeId",
        "date",
        "status"
      ]
    },
    "Justification": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Justification",
      "type": "object",
      "description": "Represents a justification for an absence or tardiness.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the justification."
        },
        "employeeId": {
          "type": "string",
          "description": "The ID of the employee this justification belongs to."
        },
        "date": {
          "type": "string",
          "format": "date-time",
          "description": "The date of the absence or tardiness being justified."
        },
        "type": {
          "type": "string",
          "description": "The type of justification.",
          "enum": ["Salud", "Motivos personales o familiares", "Estudio o capacitación", "Laborales", "Transporte", "Otros"]
        },
        "notes": {
          "type": "string",
          "description": "Detailed notes for the justification."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the justification was created."
        }
      },
      "required": ["id", "employeeId", "date", "type", "notes", "createdAt"]
    },
    "Coordinador": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Coordinador",
      "type": "object",
      "description": "Represents a coordinator.",
      "properties": {
        "id": {
          "type": "string"
        },
        "nombreCoordinador": {
          "type": "string"
        },
        "activo": {
          "type": "boolean"
        }
      },
      "required": ["id", "nombreCoordinador", "activo"]
    },
    "Division": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Division",
      "type": "object",
      "description": "Represents a division or department.",
      "properties": {
        "id": {
          "type": "string"
        },
        "nombreDivision": {
          "type": "string"
        },
        "descripcion": {
          "type": "string"
        }
      },
      "required": ["id", "nombreDivision"]
    },
    "ScrumMaster": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ScrumMaster",
      "type": "object",
      "description": "Represents a Scrum Master.",
      "properties": {
        "id": {
          "type": "string"
        },
        "nombreScrumMaster": {
          "type": "string"
        },
        "activo": {
          "type": "boolean"
        }
      },
      "required": ["id", "nombreScrumMaster", "activo"]
    },
    "Proyecto": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Proyecto",
      "type": "object",
      "description": "Represents a project.",
      "properties": {
        "id": {
          "type": "string"
        },
        "codigoProyecto": {
          "type": "string"
        },
        "nombreProyecto": {
          "type": "string"
        },
        "descripcion": {
          "type": "string"
        },
        "activo": {
          "type": "boolean"
        }
      },
      "required": ["id", "codigoProyecto", "nombreProyecto", "activo"]
    },
    "Sede": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Sede",
      "type": "object",
      "description": "Represents an office location.",
      "properties": {
        "id": {
          "type": "string"
        },
        "nombreSede": {
          "type": "string"
        },
        "direccion": {
          "type": "string"
        },
        "activo": {
          "type": "boolean"
        }
      },
      "required": ["id", "nombreSede", "activo"]
    },
    "RelacionDivision": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "RelacionDivision",
      "type": "object",
      "description": "Represents the relationship between a Scrum Master, a coordinator, and a division.",
      "properties": {
        "id": {
          "type": "string"
        },
        "scrumMasterId": {
          "type": "string"
        },
        "coordinadorId": {
          "type": "string"
        },
        "divisionId": {
          "type": "string"
        }
      },
      "required": ["id", "scrumMasterId", "coordinadorId", "divisionId"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/entities/User"
          },
          "description": "Stores user profile information, including their role.",
          "params": [
            {
              "name": "userId",
              "description": "Unique identifier for the user, same as Firebase Auth UID."
            }
          ]
        }
      },
      {
        "path": "/employees/{employeeId}",
        "definition": {
          "entityName": "Employee",
          "schema": {
            "$ref": "#/entities/Employee"
          },
          "description": "Stores employee information. The employeeId is the unique identifier for each employee.",
          "params": [
            {
              "name": "employeeId",
              "description": "Unique identifier for the employee."
            }
          ]
        }
      },
      {
        "path": "/conocimientos/{employeeId}",
        "definition": {
            "entityName": "ConocimientoEmpleado",
            "schema": {
                "$ref": "#/entities/ConocimientoEmpleado"
            },
            "description": "Stores employee skills and knowledge information. The employeeId is the DNI of the employee.",
            "params": [
                {
                    "name": "employeeId",
                    "description": "DNI of the employee."
                }
            ]
        }
      },
      {
        "path": "/employees/{employeeId}/attendance/{attendanceId}",
        "definition": {
          "entityName": "AttendanceRecord",
          "schema": {
            "$ref": "#/entities/AttendanceRecord"
          },
          "description": "Stores attendance records for each employee. The attendanceId is the unique identifier for each attendance record. Includes denormalized employeeId for authorization independence.",
          "params": [
            {
              "name": "employeeId",
              "description": "Unique identifier for the employee."
            },
            {
              "name": "attendanceId",
              "description": "Unique identifier for the attendance record."
            }
          ]
        }
      },
       {
        "path": "/justifications/{justificationId}",
        "definition": {
          "entityName": "Justification",
          "schema": {
            "$ref": "#/entities/Justification"
          },
          "description": "Stores justifications for absences and tardiness.",
          "params": [
            {
              "name": "justificationId",
              "description": "Unique identifier for the justification."
            }
          ]
        }
      },
      {
        "path": "/coordinadoresDivision/{coordinadorId}",
        "definition": {
          "entityName": "Coordinador",
          "schema": {
            "$ref": "#/entities/Coordinador"
          },
          "description": "Stores coordinator information.",
          "params": [
            {
              "name": "coordinadorId",
              "description": "Unique identifier for the coordinator."
            }
          ]
        }
      },
      {
        "path": "/divisiones/{divisionId}",
        "definition": {
          "entityName": "Division",
          "schema": {
            "$ref": "#/entities/Division"
          },
          "description": "Stores division information.",
          "params": [
            {
              "name": "divisionId",
              "description": "Unique identifier for the division."
            }
          ]
        }
      },
      {
        "path": "/scrumMasters/{scrumMasterId}",
        "definition": {
          "entityName": "ScrumMaster",
          "schema": {
            "$ref": "#/entities/ScrumMaster"
          },
          "description": "Stores Scrum Master information.",
          "params": [
            {
              "name": "scrumMasterId",
              "description": "Unique identifier for the Scrum Master."
            }
          ]
        }
      },
      {
        "path": "/proyectos/{proyectoId}",
        "definition": {
          "entityName": "Proyecto",
          "schema": {
            "$ref": "#/entities/Proyecto"
          },
          "description": "Stores project information.",
          "params": [
            {
              "name": "proyectoId",
              "description": "Unique identifier for the project."
            }
          ]
        }
      },
      {
        "path": "/sedes/{sedeId}",
        "definition": {
          "entityName": "Sede",
          "schema": {
            "$ref": "#/entities/Sede"
          },
          "description": "Stores office location information.",
          "params": [
            {
              "name": "sedeId",
              "description": "Unique identifier for the office location."
            }
          ]
        }
      },
      {
        "path": "/relacionesDivision/{relacionId}",
        "definition": {
          "entityName": "RelacionDivision",
          "schema": {
            "$ref": "#/entities/RelacionDivision"
          },
          "description": "Stores the relationship between coordinators and divisions.",
          "params": [
            {
              "name": "relacionId",
              "description": "Unique identifier for the relationship."
            }
          ]
        }
      }
    ]
  }
}

    